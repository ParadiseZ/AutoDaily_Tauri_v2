{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "auto_daily",
  "version": "0.1.0",
  "identifier": "com.smart.autodaily",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:9999",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "AutoDaily",
        "title": "AutoDaily",
        "width": 1280,
        "height": 720,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["./models/**/*"],
    "windows": {
      "nsis": {
        "installerHooks": "./windows/nsis-hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc5ODI4RDRCRDAwMzQyMjUKUldRbFFnUFFTNDJDZVZTTTBOSitYSmV1M1NqcmdJZyt4M21ZR2kwVkpNaEI2OUpJM2tyeUZKY0cK",
      "endpoints": [
        "https://raw.githubusercontent.com/ParadiseZ/AutoDailyTauriRelease/main/latest.json",
        "http://localhost:8080/api/update/{{target}}/{{arch}}/{{current_version}}"
      ],
      "windows": {
        "installMode": "passive"
      }
    },
    "server_config": {
      "remote_config_url": "https://raw.githubusercontent.com/ParadiseZ/AutoDailyTauriRelease/main/server-config.json",
      "default_server_url": "http://localhost:8080"
    }
  }
}
